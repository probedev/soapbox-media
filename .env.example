# soapbox.media environment variables
# Copy to .env.local and fill in. Production values live in Vercel.

# Supabase (Day 1)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Anthropic (Day 3). Generate at console.anthropic.com, NOT the same as
# your Claude.ai Pro account. Set a monthly cap on the key.
ANTHROPIC_API_KEY=

# PodScan (Day 2). From podscan.fm.
PODSCAN_API_KEY=

# YouTube Data API v3 (Day 2). From Google Cloud Console.
YOUTUBE_API_KEY=

# Inngest (Day 2, currently unused; reserved for v2 background jobs).
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# Vercel Cron (Day 5). Random secret authorizing /api/cron/pipeline.
# Vercel auto-attaches `Authorization: Bearer ${CRON_SECRET}` to scheduled invocations.
# Generate with: openssl rand -base64 32
CRON_SECRET=

# Admin auth (v0.6). Basic-Auth password protecting /admin/*.
# Generate with: openssl rand -base64 24
ADMIN_PASSWORD=

# PostHog (Day 4-5). Product analytics. From posthog.com.
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
